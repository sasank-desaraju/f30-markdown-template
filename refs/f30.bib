  urldate = {2026-05-16},
  abstract = {Abstract             CAR T cells targeting IL13R{$\alpha$}2 proved effective against recurrent multifocal leptomeningeal glioblastoma, according to a case report. Direct delivery of the therapy into the cerebrospinal fluid was well tolerated, completely eliminating the patient's brain and spinal tumors for 7.5 months, during which the patient resumed his normal activities.},
